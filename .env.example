# Zammad API — used by /api/contact and /api/3d-quote to create tickets.
# ZAMMAD_URL is the public Zammad base URL (no trailing slash, no /api path).
# ZAMMAD_API_TOKEN comes from Zammad: Profile → Token Access → Create.
ZAMMAD_URL=https://support.barnstormit.com
ZAMMAD_API_TOKEN=

# RESEND_API_KEY is no longer used by the website forms — those post
# directly to Zammad above. Leaving the var documented for any future
# transactional-email use.
# RESEND_API_KEY=
