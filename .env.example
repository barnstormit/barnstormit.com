# Resend API key for the /api/contact form.
# Sign in and create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Credentials for the /ops/* private area (HTTP Basic auth).
# Must also be set in the Vercel project env vars for production.
# Pick a long random password; rotate if a device is lost or staff changes.
OPS_USERNAME=
OPS_PASSWORD=
